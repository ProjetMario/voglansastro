---
import Base from "../layouts/Base.astro";
---
<Base title="Contact — Voglans">
  <section class="max-w-3xl">
    <h1 class="text-3xl font-semibold tracking-tight">Contact</h1>
    <p class="mt-3 text-neutral-600">Une question ? Laissez-nous un message.</p>

    <form class="mt-8 grid gap-4 max-w-xl">
      <div>
        <label class="block text-sm font-medium mb-1">Nom</label>
        <input type="text" class="w-full rounded-md border border-[hsl(var(--border))] px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[hsl(var(--ring))]" placeholder="Votre nom" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Email</label>
        <input type="email" class="w-full rounded-md border border-[hsl(var(--border))] px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[hsl(var(--ring))]" placeholder="vous@example.com" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Message</label>
        <textarea rows="5" class="w-full rounded-md border border-[hsl(var(--border))] px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[hsl(var(--ring))]" placeholder="Votre message..."></textarea>
      </div>
      <button type="submit" class="inline-flex items-center rounded-md px-4 py-2 bg-[hsl(var(--primary))] text-white hover:brightness-110 transition w-fit">Envoyer</button>
    </form>
  </section>
</Base>
