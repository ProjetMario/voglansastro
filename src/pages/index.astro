---
import Base from "../layouts/Base.astro";
---

<Base title="Accueil — Voglans" className="bg-[hsl(var(--background))]">
  <section class="py-16">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight">
        Design pur et élégant, avec une touche tricolore.
      </h1>
      <p class="mt-4 text-neutral-600 leading-relaxed">
        Un thème minimaliste, rapide et réutilisable pour vos sites Astro.
        Typographie nette, espaces généreux, et accents bleu-blanc-rouge discrets.
      </p>
      <div class="mt-8 flex items-center gap-4">
        <a href="/cta" class="inline-flex items-center rounded-md px-5 py-3 bg-[hsl(var(--primary))] text-white hover:brightness-110 transition">
          Commencer
        </a>
        <a href="/about" class="text-[hsl(var(--primary))] hover:underline">En savoir plus</a>
      </div>
    </div>
  </section>

  <section class="grid md:grid-cols-3 gap-6">
    <div class="p-6 elevated rounded-lg">
      <h3 class="font-medium text-lg">Rapide</h3>
      <p class="mt-2 text-neutral-600">Astro + Tailwind pour des performances de premier plan.</p>
    </div>
    <div class="p-6 elevated rounded-lg">
      <h3 class="font-medium text-lg">Épuré</h3>
      <p class="mt-2 text-neutral-600">Typographie système et espaces blancs maîtrisés.</p>
    </div>
    <div class="p-6 elevated rounded-lg">
      <h3 class="font-medium text-lg">Tricolore</h3>
      <p class="mt-2 text-neutral-600">Accents bleu, blanc, rouge élégants et subtils.</p>
    </div>
  </section>
</Base>
